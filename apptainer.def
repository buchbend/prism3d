Bootstrap: docker
From: python:3.11-slim

%labels
    Author PRISM-3D Team
    Version 0.6
    Description 3D PDR code with THEMIS dust evolution, Rust-accelerated physics, and ML chemistry

%post
    apt-get update && apt-get install -y --no-install-recommends \
        gcc g++ gfortran libhdf5-dev curl && \
    rm -rf /var/lib/apt/lists/*

    # Install Rust toolchain (needed for PyO3/maturin build)
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable
    . /root/.cargo/env

    pip install --no-cache-dir maturin
    pip install --no-cache-dir \
        numpy scipy matplotlib scikit-learn \
        astropy astroquery h5py

    mkdir -p /opt/prism3d

%files
    prism3d /opt/prism3d/prism3d
    rust /opt/prism3d/rust
    Cargo.toml /opt/prism3d/Cargo.toml
    pyproject.toml /opt/prism3d/pyproject.toml

%post
    . /root/.cargo/env
    cd /opt/prism3d && maturin build --release --out dist
    pip install --no-cache-dir --force-reinstall dist/*.whl

    # Copy the compiled .so into the source tree so it works with
    # both site-packages import and PYTHONPATH=/opt/prism3d (bind-mount dev)
    SO_FILE=$(find /usr/local/lib -name "_prism3d_core*.so" 2>/dev/null | head -1)
    if [ -n "$SO_FILE" ]; then
        cp "$SO_FILE" /opt/prism3d/prism3d/
        echo "Rust .so copied: $(basename $SO_FILE)"
    fi

    # Verify Rust core loaded (from source tree path, as container-run uses)
    cd /opt/prism3d
    python -c "from prism3d._rust_backend import has_rust; assert has_rust(), 'Rust core missing!'; print('Rust core verified')"

    # Clean up Rust build artifacts to save image size
    rm -rf /opt/prism3d/dist /opt/prism3d/target /root/.cargo/registry /root/.cargo/git
    rm -rf /root/.rustup/toolchains/*/share

%environment
    export PYTHONPATH=/opt/prism3d:$PYTHONPATH
    export PRISM3D_HOME=/opt/prism3d

%runscript
    exec python -m prism3d.run "$@"

%test
    python -c "
from prism3d.solver_3d import PDRSolver3D
from prism3d._rust_backend import has_rust
print(f'PRISM-3D OK, Rust backend: {has_rust()}')
assert has_rust(), 'Rust core should be available in container'
"

%help
    PRISM-3D v0.6 — 3D PDR code with Rust-accelerated physics.

    Rust core provides 5-15x speedup for thermal, chemistry, and PE heating.
    Python fallback remains available if Rust build fails.

    Run a model:
      apptainer run prism3d.sif --n 32 --G0 1000 --output ./results

    Run with config:
      apptainer run prism3d.sif --config model.json

    Orion Bar preset:
      apptainer run prism3d.sif --orion-bar --n 64

    Train ML accelerator:
      apptainer exec prism3d.sif python -m prism3d.chemistry.train_hpc \
          --n-samples 50000 --output training.npz

    Interactive shell:
      apptainer shell prism3d.sif
